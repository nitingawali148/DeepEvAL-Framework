# =========================================================================
# DeepEval Framework — environment template (copy to .env, then export)
# =========================================================================

# Pick which LLM judges DeepEval metrics
#   openai | groq | ollama
JUDGE_PROVIDER=groq

# Per-provider model selection
JUDGE_MODEL_OPENAI=gpt-4o-mini
JUDGE_MODEL_GROQ=openai/gpt-oss-120b
JUDGE_MODEL_OLLAMA=gpt-oss:20b

# OpenAI
OPENAI_API_KEY=

# Groq (also reused by Subsystem A and B for generation)
GROQ_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Targets — running URLs of Subsystem A and B
CHATBOT_URL=http://localhost:8201
RAG_URL=http://localhost:8202

# Optional: cap the number of golden cases per test (useful for dev)
MAX_GOLDENS=
